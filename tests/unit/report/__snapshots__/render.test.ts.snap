// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderReport > snapshots a full render 1`] = `
"<!DOCTYPE html><html lang="en"><head><meta charSet="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><meta name="referrer" content="no-referrer"/><title>GEO Report — stripe.com</title><style>/* Hybrid report aesthetic — cream bg, sans-serif body, mono accents, orange brand */

* { box-sizing: border-box; margin: 0; padding: 0; }

html { font-size: 15px; }
body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  color: #1a1a1a;
  background: #fafaf7;
  line-height: 1.55;
  padding: 40px 24px 80px;
}

.page { max-width: 860px; margin: 0 auto; }

/* Typography */
h1, h2, h3, h4 { color: #1a1a1a; font-weight: 600; }
h1 { font-size: 32px; letter-spacing: -0.01em; }
h2 { font-size: 20px; margin: 48px 0 14px; border-bottom: 1px solid #e6e2d9; padding-bottom: 8px; }
h3 { font-size: 16px; margin-bottom: 10px; }
p { font-size: 14px; color: #333; }

.mono { font-family: 'JetBrains Mono', 'SF Mono', Consolas, monospace; }
.uppercase-label { font-size: 10px; letter-spacing: 0.1em; color: #888; text-transform: uppercase; }
.muted { color: #888; }
.small { font-size: 11px; }

.brand { color: #ff7a1a; }
.good { color: #2a8a4a; }
.warn { color: #d97700; }
.bad { color: #c23030; }

/* TOC */
.toc { background: #ffffff; border: 1px solid #e6e2d9; padding: 16px 20px; margin-bottom: 32px; }
.toc ol { list-style: none; counter-reset: toc; }
.toc li { counter-increment: toc; padding: 4px 0; font-size: 13px; }
.toc li::before { content: counter(toc) ". "; color: #888; margin-right: 6px; }
.toc a { color: #1a1a1a; text-decoration: none; }
.toc a:hover { color: #ff7a1a; }

/* Cover */
.cover { padding: 24px 0 32px; border-bottom: 1px solid #e6e2d9; margin-bottom: 0; }
.cover-header { font-size: 10px; letter-spacing: 0.12em; color: #ff7a1a; text-transform: uppercase; font-weight: 600; margin-bottom: 10px; }
.cover-domain { font-size: 22px; font-weight: 500; margin-bottom: 24px; }
.cover-score { display: flex; align-items: baseline; gap: 20px; padding: 20px 0; border-top: 2px solid #1a1a1a; border-bottom: 1px solid #e6e2d9; }
.cover-letter { font-family: 'JetBrains Mono', monospace; font-size: 72px; font-weight: 700; line-height: 1; }
.cover-overall { font-size: 30px; font-weight: 500; }
.cover-meta { font-size: 11px; color: #666; margin-top: 14px; }
.cover-actions { margin-top: 14px; }
.cover-actions a { display: inline-block; background: #1a1a1a; color: #fff; padding: 8px 14px; font-size: 12px; text-decoration: none; margin-right: 8px; }

/* Scorecard */
.scorecard { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.tile { background: #ffffff; border: 1px solid #e6e2d9; padding: 16px; }
.tile-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
.tile-number { font-family: 'JetBrains Mono', monospace; font-size: 28px; font-weight: 700; line-height: 1; }
.tile-number .unit { color: #bbb; font-size: 14px; }
.tile-bar { height: 3px; background: #f0ece2; margin: 10px 0; overflow: hidden; }
.tile-bar > div { height: 100%; }
.tile-summary { font-size: 11px; color: #555; line-height: 1.4; }

/* Raw responses */
.probe-group { background: #ffffff; border: 1px solid #e6e2d9; margin-bottom: 8px; }
.probe-header { padding: 12px 16px; border-bottom: 1px solid #f0ece2; background: #faf7ee; }
.probe-answers { padding: 0; }
.probe-answer { padding: 14px 16px; border-bottom: 1px solid #f0ece2; }
.probe-answer:last-child { border-bottom: 0; }
.probe-answer-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px; }
.probe-answer-body { font-size: 12px; color: #444; line-height: 1.6; font-family: Georgia, serif; }

/* Accuracy table */
.accuracy-card { background: #ffffff; border: 1px solid #e6e2d9; padding: 16px; margin-bottom: 16px; }
.accuracy-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.accuracy-table th { text-align: left; padding: 6px 8px; font-size: 10px; letter-spacing: 0.05em; color: #666; font-weight: 500; border-bottom: 1px solid #1a1a1a; }
.accuracy-table td { padding: 8px; vertical-align: top; border-bottom: 1px solid #f0ece2; }
.accuracy-table tr.truth { background: #f5fff7; }
.accuracy-table tr.truth td { color: #333; font-family: Georgia, serif; }
.accuracy-summary { background: #fafaf2; border-top: 1px solid #f0ece2; margin: 12px -16px -16px; padding: 10px 16px; font-size: 11px; color: #333; }

/* SEO checklist */
.seo-list { background: #ffffff; border: 1px solid #e6e2d9; padding: 16px; }
.seo-row { display: flex; gap: 10px; padding: 8px 0; border-bottom: 1px solid #f0ece2; }
.seo-row:last-child { border-bottom: 0; }
.seo-row.fail { background: #fff7f2; margin: 0 -16px; padding-left: 16px; padding-right: 16px; }
.seo-mark { font-family: 'JetBrains Mono', monospace; font-size: 14px; width: 14px; }
.seo-label { font-size: 12px; font-weight: 500; }
.seo-detail { font-size: 11px; color: #888; font-family: 'JetBrains Mono', monospace; }

/* Recommendations */
.rec-card { background: #ffffff; border: 1px solid #e6e2d9; padding: 20px; margin-bottom: 12px; display: grid; grid-template-columns: 1fr 140px; gap: 20px; }
.rec-header { font-size: 10px; letter-spacing: 0.1em; color: #888; text-transform: uppercase; margin-bottom: 4px; }
.rec-title { font-size: 18px; font-weight: 600; margin-bottom: 10px; color: #1a1a1a; }
.rec-prose { font-size: 13px; line-height: 1.6; color: #333; margin-bottom: 12px; }
.rec-how { background: #faf7ee; border-left: 2px solid #ff7a1a; padding: 10px 12px; font-size: 12px; color: #444; line-height: 1.5; }
.rec-rail { border-left: 1px solid #f0ece2; padding-left: 16px; }
.rec-priority { font-family: 'JetBrains Mono', monospace; font-size: 28px; font-weight: 700; color: #ff7a1a; line-height: 1; }
.rec-priority-label { font-size: 9px; letter-spacing: 0.1em; color: #888; text-transform: uppercase; margin-bottom: 16px; }
.rec-bar-label { font-size: 10px; color: #888; margin-bottom: 4px; }
.rec-bar { height: 4px; background: #f0ece2; margin-bottom: 10px; }
.rec-bar > div { height: 100%; background: #ff7a1a; }
.rec-bar.effort > div { background: #bbb; }

/* Methodology */
.method dl { margin-top: 14px; }
.method dt { font-size: 13px; font-weight: 600; margin-top: 12px; color: #1a1a1a; }
.method dd { font-size: 13px; color: #444; line-height: 1.5; }
.method ul { margin-left: 20px; font-size: 13px; color: #333; line-height: 1.6; }

/* Print / PDF */
@media print {
  body { background: #fff; padding: 0; }
  .page { max-width: none; }
  details { display: block !important; }
  summary { display: none !important; }
  details > *:not(summary) { display: block !important; }
  .cover-actions { display: none; }
  section { page-break-inside: avoid; }
  .rec-card, .accuracy-card, .tile, .probe-group { page-break-inside: avoid; }
}
</style></head><body><div class="page"><section id="cover" class="cover"><div class="cover-header">GEO Report</div><h1 class="cover-domain">stripe.com</h1><div class="cover-score"><div class="cover-letter mono">B+</div><div><div class="cover-overall">87<span class="muted"> / 100</span></div><div class="uppercase-label">overall</div></div></div><div class="cover-meta">graded 2026-04-19 14:32 UTC</div><div class="cover-actions"><a href="/report/x.pdf?t=tok">Download PDF</a></div></section><nav class="toc" aria-label="Table of contents"><div class="uppercase-label">Contents</div><ol><li><a href="#cover">Cover</a></li><li><a href="#scorecard">Scorecard</a></li><li><a href="#raw-responses">Raw LLM responses</a></li><li><a href="#accuracy">Accuracy appendix</a></li><li><a href="#seo">SEO findings</a></li><li><a href="#recommendations">Recommendations</a></li><li><a href="#methodology">Methodology</a></li></ol></nav><section id="scorecard"><h2>Scorecard</h2><div class="scorecard"><div class="tile"><div class="tile-header"><div class="uppercase-label">Discoverability</div><div class="uppercase-label">30%</div></div><div class="tile-number mono" style="color:#1a1a1a">78<span class="unit">/100</span></div><div class="tile-bar"><div style="width:78%;background:#ff7a1a"></div></div><div class="tile-summary">LLMs find you sometimes, miss you often.</div></div><div class="tile"><div class="tile-header"><div class="uppercase-label">Recognition</div><div class="uppercase-label">20%</div></div><div class="tile-number mono" style="color:#1a1a1a">85<span class="unit">/100</span></div><div class="tile-bar"><div style="width:85%;background:#ff7a1a"></div></div><div class="tile-summary">Your brand name is correctly associated with your category.</div></div><div class="tile"><div class="tile-header"><div class="uppercase-label">Accuracy</div><div class="uppercase-label">20%</div></div><div class="tile-number mono" style="color:#d97700">62<span class="unit">/100</span></div><div class="tile-bar"><div style="width:62%;background:#d97700"></div></div><div class="tile-summary">Mixed. LLMs know some facts but invent others.</div></div><div class="tile"><div class="tile-header"><div class="uppercase-label">Coverage</div><div class="uppercase-label">10%</div></div><div class="tile-number mono" style="color:#1a1a1a">71<span class="unit">/100</span></div><div class="tile-bar"><div style="width:71%;background:#ff7a1a"></div></div><div class="tile-summary">LLMs know the main pages but miss deeper content.</div></div><div class="tile"><div class="tile-header"><div class="uppercase-label">Citation</div><div class="uppercase-label">10%</div></div><div class="tile-number mono" style="color:#1a1a1a">80<span class="unit">/100</span></div><div class="tile-bar"><div style="width:80%;background:#ff7a1a"></div></div><div class="tile-summary">LLMs correctly cite your domain as the source.</div></div><div class="tile"><div class="tile-header"><div class="uppercase-label">SEO</div><div class="uppercase-label">10%</div></div><div class="tile-number mono" style="color:#2a8a4a">93<span class="unit">/100</span></div><div class="tile-bar"><div style="width:93%;background:#2a8a4a"></div></div><div class="tile-summary">Most signals pass.</div></div></div></section><section id="raw-responses"><h2>Raw LLM responses</h2><details class="probe-group" open=""><summary class="probe-header"><div class="uppercase-label">discoverability probe</div><div><strong>&quot;What is stripe.com?&quot;</strong></div></summary><div class="probe-answers"><div class="probe-answer"><div class="probe-answer-head"><div><strong>Claude</strong> <span class="muted small mono">claude-sonnet-4-6</span></div><div class="small mono muted">score 78</div></div><div class="probe-answer-body">A payment processor...</div></div></div></details><details class="probe-group" open=""><summary class="probe-header"><div class="uppercase-label">recognition probe</div><div><strong>&quot;What does stripe do?&quot;</strong></div></summary><div class="probe-answers"><div class="probe-answer"><div class="probe-answer-head"><div><strong>Claude</strong> <span class="muted small mono">claude-sonnet-4-6</span></div><div class="small mono muted">score 85</div></div><div class="probe-answer-body">Payment processing.</div></div></div></details></section><section id="accuracy"><h2>Accuracy appendix</h2><div class="accuracy-card"><div class="uppercase-label">Probe 1 of 1</div><h3>&quot;What are stripe pricing tiers?&quot;</h3><table class="accuracy-table"><thead><tr><th>Source</th><th>Answer</th><th style="text-align:right;width:80px">Ruling</th></tr></thead><tbody><tr><td><strong>Claude</strong></td><td>Standard: 2.9% + 30¢.</td><td style="text-align:right"><span class="good mono small">✓</span></td></tr></tbody></table><div class="accuracy-summary"><span class="uppercase-label">Verifier ruling</span><br/>1 of 1 correct.</div></div></section><section id="seo"><h2>SEO findings</h2><div class="seo-list"><div style="display:flex;justify-content:space-between;margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid #f0ece2"><div class="small">2 signals checked</div><div class="small mono"><span class="good">1 pass</span> · <span class="bad">1 fail</span></div></div><div class="seo-row fail"><div class="seo-mark bad">✗</div><div style="flex:1"><div class="seo-label">llms_txt</div><div class="seo-detail">llms.txt missing</div></div></div><div class="seo-row "><div class="seo-mark good">✓</div><div style="flex:1"><div class="seo-label">robots_txt</div><div class="seo-detail">robots.txt OK</div></div></div></div></section><section id="recommendations"><h2>Recommendations</h2><div class="rec-card"><div><div class="rec-header">#1 · accuracy</div><h3 class="rec-title">Publish canonical pricing page</h3><p class="rec-prose">LLMs invented pricing.</p><div class="rec-how"><strong>How:</strong> Add JSON-LD Product.</div></div><div class="rec-rail"><div class="rec-priority mono">20</div><div class="rec-priority-label">priority</div><div class="rec-bar-label">IMPACT</div><div class="rec-bar"><div style="width:100%"></div></div><div class="rec-bar-label">EFFORT</div><div class="rec-bar effort"><div style="width:40%"></div></div></div></div><div class="rec-card"><div><div class="rec-header">#2 · discoverability</div><h3 class="rec-title">Add llms.txt</h3><p class="rec-prose">Missing signal.</p><div class="rec-how"><strong>How:</strong> Create /llms.txt.</div></div><div class="rec-rail"><div class="rec-priority mono">20</div><div class="rec-priority-label">priority</div><div class="rec-bar-label">IMPACT</div><div class="rec-bar"><div style="width:80%"></div></div><div class="rec-bar-label">EFFORT</div><div class="rec-bar effort"><div style="width:20%"></div></div></div></div></section><section id="methodology" class="method"><h2>Methodology</h2><h3>How we score</h3><dl><dt>Discoverability (30%)</dt><dd>Can LLMs find you from generic queries in your category?</dd><dt>Recognition (20%)</dt><dd>Do LLMs correctly associate your brand name with your category?</dd><dt>Accuracy (20%)</dt><dd>When LLMs answer specific questions about you, are the facts right? Verified against a live scrape.</dd><dt>Coverage (10%)</dt><dd>Do LLMs know the depth of your site, not just the homepage?</dd><dt>Citation (10%)</dt><dd>Do LLMs cite your domain when summarizing content from your site?</dd><dt>SEO (10%)</dt><dd>10 deterministic signals — llms.txt, robots.txt, sitemap, canonical, JSON-LD, OpenGraph, alt text, HTTPS, viewport, meta description.</dd></dl><h3>How accuracy works</h3><ul><li>A generator LLM reads a scrape of your site and writes a specific, verifiable question.</li><li>Each target LLM answers the question blind — no access to the scrape.</li><li>A verifier LLM compares each answer against the scrape and rules correct / partial / wrong.</li></ul><h3>Which LLMs graded this report</h3><ul><li>Claude Sonnet 4.6 <span class="muted small mono">(claude-sonnet-4-6)</span></li></ul><p class="small muted" style="margin-top:8px">Claude / GPT / Gemini transparently fall back to OpenRouter on provider errors. Perplexity calls its API directly.</p><h3>Grade scale</h3><ul><li>A: 90+</li><li>B: 80–89</li><li>C: 70–79</li><li>D: 60–69</li><li>F: below 60</li></ul><h3>Caveats</h3><ul><li>LLM grades drift. A single run is a snapshot, not a verdict.</li><li>Model weights update monthly — re-grade quarterly to track movement.</li><li>A score is a direction. Use the recommendations to drive improvement.</li></ul><h3>Report metadata</h3><p class="small mono muted">report 22222222-2222-2222-2222-222222222222<br/>grade 11111111-1111-1111-1111-111111111111<br/>generated 2026-04-19T14:32:00.000Z</p></section></div></body></html>"
`;
