# Vitest picks this up via Vite's `.env.test` precedence (higher than `.env`).
# Forces the Turnstile site key empty for client-side unit tests — without
# this, `TURNSTILE_ENABLED` leaks in from the dev `.env` and the form-submit
# tests time out waiting for a widget token that never arrives in JSDOM.
VITE_TURNSTILE_SITE_KEY=
